---
const editors = [
  { name: "Cursor", model: "Claude / GPT-4", plan: "Freemium", desc: "Edición precisa con IA, multi-archivo." },
  { name: "Trae", model: "Claude 4 / Gemini", plan: "Gratis", desc: "Builder Mode, Claude 4 gratis." },
  { name: "Antigravity", model: "Agent-based", plan: "De pago", desc: "Agente autónomo, testing en browser." },
  { name: "VS Code + Copilot", model: "GPT-4", plan: "De pago", desc: "El clásico mejorado con IA." },
];
---

<section class="py-24 sm:py-32">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="font-display text-3xl md:text-4xl tracking-tighter">
        Los mejores <span class="text-orange">editores con IA</span>
      </h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {editors.map(editor => (
        <div class="bg-white border border-border rounded-2xl p-6">
          <div class="flex justify-between items-start mb-4">
            <h3 class="font-display text-2xl text-ink">{editor.name}</h3>
            <span class={`text-xs font-bold uppercase px-3 py-1 rounded-full ${editor.plan === 'Gratis' ? 'bg-green-100 text-green-800' : editor.plan === 'Freemium' ? 'bg-blue-100 text-blue-800' : 'bg-orange-pale text-orange-deep'}`}>
              {editor.plan}
            </span>
          </div>
          <p class="text-ink-mid mb-2"><span class="font-bold">IA:</span> {editor.model}</p>
          <p class="text-ink-mid">{editor.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
