---
interface Props {
  category: string;
  title: string;
  time: string;
  score: number;
  link?: string;
}

const { category, title, time, score, link = "#" } = Astro.props;
---

<article class="group bg-white border border-border rounded-2xl p-6 transition-all hover:border-orange hover:shadow-xl hover:shadow-orange/5 flex flex-col justify-between">
  <a href={link} target="_blank" rel="noopener noreferrer">
    <div>
      <span class="text-orange label-tag block mb-2">{category}</span>
      <h3 class="font-display text-[1rem] font-bold text-ink leading-[1.3] mb-4 group-hover:text-orange-deep transition-colors">
        {title}
      </h3>
    </div>
  </a>
  
  <div class="space-y-4">
    <div class="flex justify-between items-center">
      <span class="text-ink-mid text-sm font-medium italic">{time}</span>
      <span class="text-ink-faint text-sm font-bold uppercase tracking-widest">{score}%</span>
    </div>
    
    <!-- Progress Bar -->
    <div class="h-1.5 w-full bg-orange-pale rounded-full overflow-hidden">
      <div 
        class="h-full bg-orange rounded-full transition-all duration-1000 ease-out group-hover:bg-orange-light" 
        style={`width: ${score}%`}
      ></div>
    </div>
  </div>
</article>
