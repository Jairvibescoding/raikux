---
interface Props {
  category: string;
  title: string;
  time: string;
  score: number;
  link?: string;
}

const { category, title, time, score, link = "#" } = Astro.props;
---

<article class="glass-panel group p-7 transition-all duration-300 hover:border-orange/40 hover:shadow-2xl hover:shadow-orange/15 hover:-translate-y-1 flex flex-col justify-between relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-orange/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>

  <a href={link} target="_blank" rel="noopener noreferrer" class="relative z-10 block">
    <div>
      <span class="text-orange label-tag block mb-3 uppercase tracking-[0.15em] text-xs font-bold font-sans">{category}</span>
      <h3 class="font-display text-[1.15rem] font-bold text-white leading-[1.4] mb-5 group-hover:text-orange-light transition-colors line-clamp-3">
        {title}
      </h3>
    </div>
  </a>
  
  <div class="space-y-4 relative z-10 mt-auto pt-4 border-t border-white/5">
    <div class="flex justify-between items-center">
      <span class="text-ink-mid text-xs font-medium italic">{time}</span>
      <span class="text-ink-faint text-xs font-bold uppercase tracking-widest bg-white/5 px-2 py-1 rounded-md">{score}%</span>
    </div>
    
    <div class="h-1 w-full bg-surface-elevated rounded-full overflow-hidden relative">
      <div 
        class="absolute left-0 top-0 bottom-0 bg-gradient-to-r from-orange to-orange-deep rounded-full transition-all duration-1000 ease-out group-hover:from-orange-light group-hover:to-orange shadow-[0_0_8px_rgba(232,82,42,0.5)]" 
        style={`width: ${score}%`}
      ></div>
    </div>
  </div>
</article>
