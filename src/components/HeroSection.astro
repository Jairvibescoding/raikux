---
const ias = ["Claude 3.5 Sonnet", "GPT-4o", "Gemini 1.5 Pro", "Grok 2"];
---

<section class="relative bg-black min-h-[90vh] flex items-center overflow-hidden pt-20">
  <!-- Video Background (Desktop) -->
  <video 
    autoplay 
    loop 
    muted 
    playsinline 
    class="absolute inset-0 w-full h-full object-cover z-0 hidden md:block opacity-75 mix-blend-screen"
  >
    <source src="https://player.vimeo.com/external/375751257.hd.mp4?s=0c5b5f5c5f5c5f5c5f5c5f5c5f5c5f5c5f5c5f5c&profile_id=175" type="video/mp4" />
  </video>

  <!-- Mobile Fallback / Particles -->
  <div class="absolute inset-0 z-0 md:hidden bg-surface">
    <div class="absolute -top-[20%] -left-[10%] w-[600px] h-[600px] bg-orange/20 rounded-full blur-[100px] mix-blend-screen animate-pulse duration-[8000ms]"></div>
    <div class="absolute top-[20%] -right-[10%] w-[500px] h-[500px] bg-orange-deep/15 rounded-full blur-[100px] mix-blend-screen"></div>
  </div>

  <!-- Dark Overlay & Edge Flow -->
  <div class="absolute inset-0 bg-black/60 z-10"></div>
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-surface to-transparent z-10"></div>
  <div class="absolute -left-[50%] top-0 bottom-0 w-[50%] bg-gradient-to-r from-transparent via-orange/15 to-transparent z-10 animate-[slide-right_8s_ease-in-out_infinite_alternate] pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 z-20 w-full">
    <div class="flex flex-col items-center text-center">
      <!-- Eyebrow -->
      <div class="animate-fade-up flex items-center gap-3 backdrop-blur-xl bg-white/5 border border-white/10 px-6 py-2.5 mb-8 rounded-full shadow-[0_0_20px_rgba(232,82,42,0.15)] hover:border-orange/40 hover:bg-white/10 transition-all duration-300 cursor-default">
        <span class="w-2.5 h-2.5 bg-green-500 rounded-full animate-pulse-green shadow-[0_0_8px_rgba(34,197,94,0.8)]"></span>
        <span class="text-white/90 text-xs font-bold uppercase tracking-[0.2em]">
          Actualizado en tiempo real
        </span>
      </div>

      <!-- Headline -->
      <h1 class="animate-fade-up animate-delay-100 font-display text-[3.5rem] md:text-[5.5rem] text-white mb-6 leading-[1.05] max-w-5xl tracking-tighter drop-shadow-2xl">
        El pulso base de la <br class="hidden md:block" />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-light via-orange to-orange-deep italic pr-2 drop-shadow-lg">IA & Marketing</span>.
      </h1>

      <!-- Subtitle -->
      <p class="animate-fade-up animate-delay-200 text-white/70 text-lg md:text-2xl max-w-3xl mb-12 leading-relaxed drop-shadow-md font-light">
        Análisis predictivos, rankings de grandes modelos métricos y estrategias vanguardistas para ingenieros y marketers en formato cinemático.
      </p>

      <!-- Tags -->
      <div class="flex flex-wrap justify-center gap-4 animate-fade-up animate-delay-300">
        {ias.map((ia) => (
          <span class="backdrop-blur-md bg-white/5 border border-white/10 text-white/80 px-6 py-3 text-sm font-semibold rounded-2xl hover:text-white hover:bg-orange/20 hover:border-orange/30 hover:shadow-[0_0_20px_rgba(232,82,42,0.3)] hover:scale-105 transition-all duration-300 cursor-default shadow-xl">
            {ia}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes slide-right {
    0% { transform: translateX(0); }
    100% { transform: translateX(300%); }
  }
</style>
