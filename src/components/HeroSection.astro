---
const ias = ["Claude 3.5 Sonnet", "GPT-4o", "Gemini 1.5 Pro", "Grok 2"];
---

<section class="relative bg-surface overflow-hidden py-24 sm:py-32">
  <!-- Glowing Background Orbs -->
  <div class="absolute -top-[20%] -left-[10%] w-[600px] h-[600px] bg-orange/15 rounded-full blur-[100px] mix-blend-screen animate-pulse duration-[8000ms]"></div>
  <div class="absolute top-[20%] -right-[10%] w-[500px] h-[500px] bg-orange-deep/10 rounded-full blur-[100px] mix-blend-screen"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 z-10">
    <div class="flex flex-col items-center text-center">
      <!-- Eyebrow -->
      <div class="animate-fade-up flex items-center gap-3 glass-panel px-5 py-2.5 mb-8 hover:bg-white/5 transition-colors cursor-default">
        <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse-green"></span>
        <span class="text-white/80 text-xs font-semibold uppercase tracking-[0.15em]">
          Actualizado en tiempo real
        </span>
      </div>

      <!-- Headline -->
      <h1 class="animate-fade-up animate-delay-100 font-display text-[3rem] md:text-[4.5rem] text-white mb-6 leading-[1.05] max-w-5xl tracking-tighter">
        El pulso core de la <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-light to-orange-deep italic pr-2">IA & Marketing</span> en un solo nexo.
      </h1>

      <!-- Subtitle -->
      <p class="animate-fade-up animate-delay-200 text-ink-mid text-lg md:text-xl max-w-2xl mb-12 leading-relaxed">
        Análisis predictivos, rankings de grandes modelos matemáticos y estrategias vanguardistas para ingenieros y marketers.
      </p>

      <!-- Tags -->
      <div class="flex flex-wrap justify-center gap-3 animate-fade-up animate-delay-300">
        {ias.map((ia) => (
          <span class="glass-panel text-ink-mid px-5 py-2.5 text-sm font-medium hover:text-white hover:bg-white/10 hover:border-white/20 transition-all cursor-default transform hover:scale-105">
            {ia}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
