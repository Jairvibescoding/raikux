---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/marketing/Hero.astro';
import Tools from '../components/marketing/Tools.astro';
import AIRecommender from '../components/marketing/AIRecommender.tsx';
import CommunityPoll from '../components/marketing/CommunityPoll.tsx';
---

<BaseLayout title="Marketing — IA & Estrategia Digital" currentPath="/marketing">
  <Navbar />
  <main>
    <Hero />
    <Tools />
    <section class="py-24 sm:py-32 bg-surface">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <AIRecommender client:visible />
      </div>
    </section>
    <section class="py-24 sm:py-32">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <CommunityPoll client:visible />
      </div>
    </section>
  </main>
</BaseLayout>
