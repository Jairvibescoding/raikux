---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog — Deep Dives en IA y Marketing" description="Artículos y análisis cinemáticos sobre IA y Marketing">
  <Navbar />
  
  <main class="w-full relative min-h-screen">
    <!-- Header visual -->
    <div class="relative w-full h-[50vh] flex items-center justify-center overflow-hidden bg-black -mt-20 z-0">
      <div class="absolute inset-0 bg-gradient-to-tr from-orange-deep/20 via-orange/5 to-transparent pointer-events-none opacity-50 z-0 mix-blend-screen animate-pulse duration-[8000ms]"></div>
      <div class="relative z-10 text-center animate-fade-up">
        <h1 class="font-display text-5xl md:text-7xl text-white mb-6 tracking-tighter drop-shadow-2xl">
          Deep <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-light to-orange drop-shadow-none">Dives</span>
        </h1>
        <p class="text-white/70 text-lg md:text-xl max-w-2xl mx-auto px-4 font-light">
          Análisis extendido y material educativo de alto impacto.
        </p>
      </div>
      <div class="absolute inset-0 bg-gradient-to-t from-surface to-transparent z-10 pointer-events-none"></div>
    </div>

    <!-- Grid -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-32 relative z-20 -mt-16">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" data-animate>
        {posts.map((post, index) => (
          <a href={`/raikux/blog/${post.id}/`} class="relative overflow-hidden glass-panel group block hover:-translate-y-2 hover:shadow-[0_30px_60px_-15px_rgba(232,82,42,0.3)] hover:border-orange/50 transition-all duration-500 flex flex-col h-full animate-fade-up min-h-[400px] border-white/10" style={`animation-delay: ${(index) * 150}ms`}>
            
            {/* Imagen Cover Base (Todo el fondo) */}
            <div class="absolute inset-0 bg-surface z-0">
              {post.data.thumbnail && (
                <img src={post.data.thumbnail} alt={post.data.title} class="absolute inset-0 w-full h-full object-cover opacity-40 group-hover:opacity-60 group-hover:scale-110 transition-all duration-[800ms] ease-out saturate-50 group-hover:saturate-100" loading="lazy" />
              )}
            </div>

            {/* Gradient Overlay Oscuro por Defecto */}
            <div class="absolute inset-0 bg-gradient-to-t from-black/95 via-black/70 to-transparent z-0 group-hover:from-black/80 transition-all duration-500"></div>

            <div class="relative z-10 flex flex-col h-full p-8">
              <div class="flex items-center justify-between mb-auto">
                <span class="bg-orange/90 text-white backdrop-blur-md px-3 py-1 rounded-md text-xs font-bold uppercase tracking-[0.15em] shadow-[0_0_10px_rgba(232,82,42,0.5)]">
                  {post.data.category}
                </span>
              </div>
              
              <div class="mt-auto pt-8 group-hover:translate-y-0 transition-transform duration-500">
                <div class="text-orange-pale/70 text-xs font-bold tracking-widest mb-3 uppercase">
                  {post.data.date.toLocaleDateString('es-ES', { year: 'numeric', month: 'short', day: 'numeric' })}
                </div>
                <h2 class="font-display text-2xl text-white mb-4 group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-orange-light group-hover:to-orange transition-colors leading-[1.2] drop-shadow-md">
                  {post.data.title}
                </h2>
                {/* Hover overlay expansion */}
                <div class="h-0 overflow-hidden opacity-0 group-hover:h-auto group-hover:opacity-100 group-hover:mt-4 transition-all duration-500 text-white/80 text-sm leading-relaxed border-l-2 border-orange pl-4 pointer-events-none">
                  {post.data.description}
                </div>
              </div>
            </div>
            
            {/* Edge Glow effect */}
            <div class="absolute inset-0 pointer-events-none rounded-2xl ring-1 ring-white/10 group-hover:ring-orange/30 group-hover:shadow-[inset_0_0_20px_rgba(232,82,42,0.2)] transition-all z-20"></div>
          </a>
        ))}
      </div>
    </div>
  </main>
</BaseLayout>
