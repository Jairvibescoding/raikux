---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import HeroSection from '../components/HeroSection.astro';
import NewsFeed from '../components/NewsFeed.tsx';
import RankingTable from '../components/RankingTable.tsx';
import RankingChart from '../components/RankingChart.tsx';
import { mockMetrics } from '../lib/mockData';
import { getAIRankings } from '../lib/supabase';

const rankings = await getAIRankings();
const top5Rankings = rankings.slice(0, 5);
const chartData = rankings.slice(0, 10).map(m => ({ name: m.name, score: m.score }));
---

<BaseLayout title="Dashboard — IA, Marketing & Dev" currentPath="/">
  <Navbar />
  
  <main>
    <HeroSection />

    <!-- Metrics Grid -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-16 relative z-10">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
        {mockMetrics.map((metric) => (
          <div class="bg-white border border-border p-6 rounded-2xl shadow-xl shadow-ink/5">
            <p class="text-ink-faint text-xs font-bold uppercase tracking-widest mb-2">{metric.label}</p>
            <div class="flex items-end justify-between">
              <h4 class="font-display text-3xl text-ink leading-none">{metric.value}</h4>
              <span class="text-green-600 text-xs font-bold">{metric.trend}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Top Ranking Section -->
    <section class="py-24 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <h2 class="font-display text-[1.8rem] text-ink tracking-tighter mb-4 leading-none uppercase">
          Top <span class="text-orange">Rankings</span> IA
        </h2>
        <p class="text-ink-mid text-lg font-medium italic opacity-70">
          Modelos con mejor desempeño en benchmarks de razonamiento.
        </p>
      </div>
      
      <RankingTable client:load data={top5Rankings} />
      
      <div class="mt-8 text-center">
        <a href="/raikux/ranking/" class="inline-flex items-center gap-2 text-ink font-bold uppercase tracking-widest text-sm hover:text-orange transition-colors">
          Ver ranking completo
          <span>→</span>
        </a>
      </div>
    </section>

    <!-- News Grid -->
    <section class="py-24 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <h2 class="font-display text-[1.8rem] text-ink tracking-tighter mb-4 leading-none uppercase">
          Últimas <span class="text-orange">Noticias</span>
        </h2>
        <p class="text-ink-mid text-lg font-medium italic opacity-70">
          Actualización en tiempo real desde las mejores fuentes globales.
        </p>
      </div>
      <NewsFeed client:load />
    </section>

    <!-- Chart Section -->
    <section class="py-24 bg-ink">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="mb-12 text-center">
          <h2 class="font-display text-[1.8rem] text-white tracking-tighter mb-4 leading-none uppercase">
            Tendencias de <span class="text-orange">Poder</span>
          </h2>
          <p class="text-white/50 text-lg font-medium italic">
            Visualización comparativa de los modelos más avanzados.
          </p>
        </div>
        
        <RankingChart client:visible data={chartData} />
      </div>
    </section>
  </main>

  <footer class="bg-surface py-12 border-t border-border">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-ink-faint text-sm font-medium">
        © 2026 RAIKU — Hecho con IA para la próxima era digital.
      </p>
    </div>
  </footer>
</BaseLayout>
