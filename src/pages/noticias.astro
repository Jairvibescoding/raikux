---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import NewsGrid from '../components/NewsGrid.astro';
import { fetchNewsFromRSS } from '../lib/rss';

const newsIA = await fetchNewsFromRSS('ia', 6);
const newsMarketing = await fetchNewsFromRSS('marketing', 6);
const newsDev = await fetchNewsFromRSS('dev', 6);
const allNews = [...newsIA, ...newsMarketing, ...newsDev];
---

<BaseLayout title="Noticias — IA & Ecosistema Digital" currentPath="/noticias">
  <Navbar />
  
  <main class="py-24 bg-surface min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <h1 class="font-display text-[1.8rem] md:text-[2.2rem] text-ink tracking-tighter mb-4 leading-none uppercase">
          Últimas <span class="text-orange">Noticias</span>
        </h1>
        <p class="text-ink-mid text-xl font-medium italic opacity-70 max-w-2xl">
          El pulso informativo de la industria tecnológica, curado por IA.
        </p>
      </div>

      <!-- Filters -->
      <div class="flex flex-wrap gap-4 mb-12">
        {["IA", "Marketing", "Programación"].map((filter) => (
          <button class="px-6 py-2 rounded-full border border-border bg-white text-ink font-bold uppercase tracking-widest text-xs hover:border-orange hover:text-orange transition-all">
            {filter}
          </button>
        ))}
      </div>

      <NewsGrid news={allNews} />
      
      <!-- Pagination Placeholder -->
      <div class="mt-16 flex justify-center gap-4">
        <button class="px-6 py-3 border border-border bg-white text-ink-faint font-bold uppercase tracking-widest text-xs cursor-not-allowed">Anterior</button>
        <button class="px-6 py-3 border border-orange bg-orange text-white font-bold uppercase tracking-widest text-xs hover:bg-orange-light transition-all shadow-lg shadow-orange/20">Siguiente</button>
      </div>
    </div>
  </main>
</BaseLayout>
